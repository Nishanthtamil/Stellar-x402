# Only for dev without Docker. Leave false so jobs fail fast if the daemon is down.
ALLOW_DOCKER_SIMULATION=false
# Dev: if true, job containers are not auto-removed so you can inspect them in Docker Desktop.
# DOCKER_KEEP_CONTAINERS=false

STELLAR_NETWORK=TESTNET
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
DEPLOYER_PUBLIC_KEY=""
DEPLOYER_SECRET=""
EXECUTOR_PUBLIC_KEY=""
EXECUTOR_SECRET=""
REGISTRY_CONTRACT_ID=""
GEMINI_API_KEY=""

# Public URL of this API (no trailing slash). Used in /api/discovery for agent endpoint + x402 hints.
PUBLIC_BASE_URL=

# Official x402 HTTP facilitator (verify + settle). Disable with X402_FACILITATOR_ENABLED=false to only allow legacy XLM tx header.
X402_FACILITATOR_URL=https://x402.org/facilitator
# X402_FACILITATOR_API_KEY=
X402_FACILITATOR_ENABLED=true
# Price in decimal USDC (default Stellar exact scheme asset). Executor must trust USDC.
X402_PRICE=0.01
# X402_STELLAR_NETWORK=TESTNET
# X402_STELLAR_ASSET=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# Optional: default gateway for resolving metadata CID (see /api/discovery/resolved)
IPFS_GATEWAY=https://ipfs.io

# Optional: Pinata JWT for scripts/publish_agent_metadata_ipfs.py
PINATA_JWT=
